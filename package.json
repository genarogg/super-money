{
  "name": "monorepo",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Monorepo con Turborepo: Astro (docs), React.js (frontend) y Fastify (backend).",
  "engines": {
    "node": "22"
  },
  "workspaces": [
    "docs",
    "frontend",
    "backend",
    "lib"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build --filter=frontend",
    "start": "turbo run start",
    "-----lib-----": "-----------------------------------------",
    "publicar": "cd lib && pnpm run publicar",
    "-----Global-----": "-----------------------------------------",
    "clean:install": "node ./global/clean.js && pnpm install"
  },
  "dependencies": {
    "turbo": "^2.7.2"
  },
  "packageManager": "pnpm@8.15.0"
}