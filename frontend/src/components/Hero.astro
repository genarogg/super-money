---
/**
 * SuperMoneyHero.astro
 * ─────────────────────────────────────────────────────────────
 * Hero section para la librería "supermoney".
 *
 * USO:
 *   import SuperMoneyHero from "@/components/SuperMoneyHero.astro";
 *   <SuperMoneyHero />
 *
 * REQUISITOS:
 *   - Tailwind CSS configurado en astro.config.mjs
 *   - Fuentes en tu layout base:
 *       https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700
 *           &family=Syne:wght@800;900&display=swap
 * ─────────────────────────────────────────────────────────────
 */

const PNPM_COMMAND = "pnpm add supermoney";

type BadgeColor = "violet" | "emerald" | "amber" | "rose";

interface TechBadge {
  label: string;
  color: BadgeColor;
}

const TECH_BADGES: TechBadge[] = [
  { label: "decimal.js",         color: "violet"  },
  { label: "TypeScript",         color: "emerald" },
  { label: "MutationObserver",   color: "amber"   },

];

const BADGE_STYLES: Record<BadgeColor, string> = {
  violet:  "bg-violet-50 border-violet-200 text-violet-600",
  emerald: "bg-emerald-50 border-emerald-200 text-emerald-600",
  amber:   "bg-amber-50 border-amber-200 text-amber-600",
  rose:    "bg-rose-50 border-rose-200 text-rose-600",
};
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-6 py-24 text-center overflow-hidden bg-white">

  <!-- Fondo: rejilla estática -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none bg-[linear-gradient(to_right,#7c3aed0a_1px,transparent_1px),linear-gradient(to_bottom,#7c3aed0a_1px,transparent_1px)] bg-[size:48px_48px]"
  />

  <!-- Glow central -->
  <div
    aria-hidden="true"
    class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[560px] h-[320px] rounded-full pointer-events-none bg-violet-500/10 blur-[120px]"
  />

  <!-- Badge superior -->
  <div class="relative z-10 mb-8">
    <span class="inline-flex items-center gap-2 font-mono text-[10px] tracking-widest uppercase font-medium text-violet-600 bg-violet-50 border border-violet-200 rounded-full px-4 py-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></span>
      powered by decimal.js · sin errores de float
    </span>
  </div>

  <!-- Título principal -->
  <h1 class="relative z-10 font-['Syne',sans-serif] text-[clamp(4rem,12vw,8rem)] font-black tracking-tighter leading-[0.88] mb-6">
    <span class="text-violet-500">super</span>
    <br />
    <span class="text-gray-900">money</span>
  </h1>

  <!-- Descripción -->
  <p class="relative z-10 text-[clamp(14px,2vw,17px)] leading-relaxed text-gray-500 font-mono max-w-[480px] mx-auto mb-10">
    <code class="text-violet-500">&lt;input type="money" /&gt;</code> para la web.
    <br />
    Modo ATM. Sin frameworks. Sin errores de punto flotante.
  </p>

  <!-- Bloque de instalación (pnpm) -->
  <div class="relative z-10 w-full max-w-md mx-auto mb-8">
    <div class="flex items-center justify-between bg-gray-900 border border-gray-800 rounded-xl px-4 py-3">
      <code id="pnpm-cmd" class="font-mono text-sm text-gray-100 select-all">{PNPM_COMMAND}</code>
      <button
        id="copy-btn"
        aria-label="Copiar comando"
        class="ml-4 p-1.5 rounded-md text-gray-500 hover:text-violet-400 transition-colors duration-200"
      >
        <!-- Lucide: Copy -->
        <svg id="icon-copy" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
        <!-- Lucide: Check (oculto por defecto) -->
        <svg id="icon-check" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-emerald-400">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- CTAs -->
  <div class="relative z-10 flex flex-wrap items-center justify-center gap-4 mb-12">
    <a
      href="#install"
      class="bg-violet-500 hover:bg-violet-600 active:scale-95 text-white font-mono text-sm font-medium px-6 py-3 rounded-xl transition-all duration-200 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/35 hover:-translate-y-px"
    >
      Empezar →
    </a>
    <a
      href="#demo"
      class="border border-violet-200 hover:border-violet-400 text-violet-600 hover:bg-violet-50 font-mono text-sm font-medium px-6 py-3 rounded-xl transition-all duration-200 hover:-translate-y-px"
    >
      Ver demo
    </a>
  </div>

  <!-- Mini demo: float vs supermoney -->
  <div class="relative z-10 mb-10">
    <div class="inline-flex items-center gap-5 bg-gray-50 border border-gray-200 rounded-2xl px-6 py-4 font-mono text-xs">
      <div class="text-center">
        <p class="text-[10px] text-gray-400 uppercase tracking-widest mb-1.5">JS nativo</p>
        <p class="text-rose-500">0.10 + 0.20 = 0.30000000000000004 ✗</p>
      </div>
      <div class="w-px h-8 bg-gray-200 shrink-0"></div>
      <div class="text-center">
        <p class="text-[10px] text-gray-400 uppercase tracking-widest mb-1.5">supermoney</p>
        <p class="text-emerald-500">0.10 + 0.20 = 0.30 ✓</p>
      </div>
    </div>
  </div>

  <!-- Badges de tecnología -->
  <div class="relative z-10 flex flex-wrap justify-center gap-3 font-mono text-[11px] font-medium">
    {TECH_BADGES.map((badge) => (
      <span class={`${BADGE_STYLES[badge.color]} border px-3 py-1.5 rounded-full transition-transform duration-200 hover:scale-105 cursor-default`}>
        {badge.label}
      </span>
    ))}
  </div>

</section>

<script>
  const btn = document.getElementById('copy-btn');
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');
  const COMMAND = "pnpm add supermoney";

  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(COMMAND);
    } catch {
      // fallback silencioso
    }

    // Mostrar ícono de check
    iconCopy?.classList.add('hidden');
    iconCheck?.classList.remove('hidden');
    btn.classList.add('text-emerald-400');
    btn.classList.remove('text-gray-500', 'hover:text-violet-400');

    setTimeout(() => {
      iconCopy?.classList.remove('hidden');
      iconCheck?.classList.add('hidden');
      btn.classList.remove('text-emerald-400');
      btn.classList.add('text-gray-500', 'hover:text-violet-400');
    }, 2000);
  });
</script>